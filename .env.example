# Evolution API connection
EVOLUTION_API_URL=https://your-evolution-api.example.com
EVOLUTION_API_INSTANCE=YourInstance
EVOLUTION_API_KEY=your-api-key-here

# Message provider mode: "n8n" (default), "webhook", or "custom"
PROVIDER_MODE=n8n

# Provider URL (used in n8n and custom modes)
# n8n default: http://localhost:5678/webhook/whatsapp-claude-poll
# custom: https://your-api.example.com
PROVIDER_URL=http://localhost:5678/webhook/whatsapp-claude-poll

# Webhook server port (only used when PROVIDER_MODE=webhook)
WHATSAPP_WEBHOOK_PORT=9801

# Project name for message routing (defaults to "default")
WHATSAPP_PROJECT=default

# Polling interval in milliseconds (default: 3000)
WHATSAPP_POLL_INTERVAL_MS=3000

# Groq API key for audio transcription (optional)
GROQ_API_KEY=

# Groq Whisper language (default: "en")
GROQ_LANGUAGE=en
